[{
	"id": "preferences",
	"children": [
		{
			"id": "package-settings",
			"children": [
				{
					"caption": "Modelines",
					"children": [
						{
							"caption": "Settings…",
							"id": "modelines-settings",
							"command": "edit_settings",
							"args": {
								"base_file": "${packages}/Modelines/Modelines.sublime-settings",
								"default": "/* See the left pane for the list of settings and valid values. */\n{\n\t$0\n}\n",
							}
						}
					]
				}
			]
		}
	]
}]
